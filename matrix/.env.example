# Matrix bootstrap module configuration
# Copy to matrix/.env and set all required values before running root docker compose

# Public homeserver URL used by Matrix clients and discovery.
# Use https:// for real domains; localhost/127.0.0.1 may use http:// for local dev.
MATRIX_DOMAIN=matrix.example.com

# Optional federation name shown to other servers; defaults to MATRIX_DOMAIN.
MATRIX_SERVER_NAME=

# Public homeserver base URL. Leave empty to default to https://MATRIX_DOMAIN.
MATRIX_PUBLIC_BASEURL=

# Optional browser-client API override for Element Web and similar clients.
# Leave empty to reuse MATRIX_PUBLIC_BASEURL.
MATRIX_CLIENT_BASEURL=

# Whether federation is enabled by default. false is recommended for private deployments.
MATRIX_FEDERATION_ENABLED=false

# ACME contact email for automatic certificate issuance and renewal.
MATRIX_ACME_EMAIL=admin@example.com

# Optional contact email used by docs/ops metadata.
MATRIX_ADMIN_EMAIL=admin@example.com

# Synapse + Postgres settings
SYNAPSE_REPORT_STATS=no
SYNAPSE_ALLOW_UNSAFE_LOCALE=true
POSTGRES_DB=synapse
POSTGRES_USER=synapse
POSTGRES_PASSWORD=change-this-strong-password

# Optional shared database name for assistant tool backends
ASSISTANT_TOOLS_DB=assistant_tools

# Shared registration secret used by admin scripts
SYNAPSE_REGISTRATION_SHARED_SECRET=change-this-random-secret

# Initial admin and assistant users
MATRIX_ADMIN_LOCALPART=admin
MATRIX_ADMIN_PASSWORD=change-this-admin-password
MATRIX_ASSISTANT_LOCALPART=assistant
MATRIX_ASSISTANT_PASSWORD=change-this-assistant-password

# Optional fixed device id for assistant password login flow
MATRIX_ASSISTANT_DEVICE_ID=assistant
