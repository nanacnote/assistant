# Assistant runtime configuration
# Copy this file to .env and fill in the real values.

# Core runtime
ASSISTANT_EVENT_WORKERS=2
ASSISTANT_QUEUE_SIZE=1000
ASSISTANT_LOG_LEVEL=INFO
ASSISTANT_ERROR_REPLY=I could not complete that request.
ASSISTANT_AGENT_MAX_STEPS=10

# Tool plugin modules (defaults to assistant.builtin_tools)
# Add custom modules here: ASSISTANT_TOOL_MODULES=assistant.builtin_tools,my_module.tools
ASSISTANT_TOOL_MODULES=

# --- Storage ---
# PostgreSQL DSN for calendar and wellbeing tool persistence.
# In Docker Compose this is injected automatically for the assistant service.
# For local non-Docker runs, set it explicitly if you want tool persistence.
ASSISTANT_DB_DSN=

# Matrix transport
# These assistant Matrix values are usually written by matrix/scripts/prefill-assistant-env.sh
# after the Matrix bootstrap flow. Leave them blank unless you are setting them manually.
# Provide an ACCESS_TOKEN only if you already have one; password login is fine for bootstrap.
ASSISTANT_MATRIX_HOMESERVER_URL=
ASSISTANT_MATRIX_USER_ID=
ASSISTANT_MATRIX_ACCESS_TOKEN=
ASSISTANT_MATRIX_PASSWORD=
ASSISTANT_MATRIX_DEVICE_ID=
ASSISTANT_MATRIX_SYNC_TIMEOUT_MS=30000
ASSISTANT_MATRIX_REQUEST_TIMEOUT_SECONDS=15.0
# Normally leave blank — the assistant primes its own sync position on startup.
# Set this only to pin the assistant to a specific stream position (e.g. after
# restoring from backup). Use matrix/scripts/ops/get_sync_token.py to capture
# and write the value automatically.
ASSISTANT_MATRIX_INITIAL_SYNC_TOKEN=

# LLM API (OpenAI-compatible chat completions endpoint)
ASSISTANT_LLM_API_URL=https://api.openai.com/v1/chat/completions
ASSISTANT_LLM_API_KEY=
ASSISTANT_LLM_MODEL=gpt-4.1-mini
ASSISTANT_LLM_SYSTEM_PROMPT=
ASSISTANT_LLM_REQUEST_TIMEOUT_SECONDS=30.0
ASSISTANT_LLM_TEMPERATURE=0.2
